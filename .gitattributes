# Force LF line endings for shell scripts and YAML (never CRLF)
# This prevents Windows CRLF from breaking CI/CD bash scripts
*.yml        text eol=lf
*.yaml       text eol=lf
*.sh         text eol=lf
Dockerfile   text eol=lf
.env*        text eol=lf

# Java and config files - normalize to LF
*.java       text eol=lf
*.xml        text eol=lf
*.properties text eol=lf
*.json       text eol=lf
*.sql        text eol=lf

# Binary files - no conversion
*.jar        binary
*.class      binary
*.png        binary
*.jpg        binary
*.jpeg       binary
*.gif        binary
*.ico        binary
*.zip        binary
